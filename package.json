{
  "name": "resend-exporter",
  "version": "0.0.0",
  "private": true,
  "description": "Prometheus exporter and webhook receiver for Resend email events",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robbeverhelst/resend-exporter.git"
  },
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile dist/resend-exporter",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "prom-client": "^15.1.3",
    "svix": "^1.99.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^11.0.0",
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "semantic-release": "^25.0.8",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
